modules = ["nodejs-20", "web", "nix"]
[agent]
expertMode = true
integrations = ["github:1.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node silva.js"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 25680
externalPort = 3000

[[ports]]
localPort = 3000
externalPort = 3000

[userenv]

[userenv.shared]
PORT = "25680"
AUTO_STATUS_REPLY = "false"
DEBUG = "true"
